{
  "title": "VertexChain Database Performance",
  "uid": "vertexchain-db",
  "tags": ["vertexchain", "postgres", "database"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Active Connections",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "pg_stat_activity_count{datname=\"vertexchain\"}",
          "legendFormat": "{{ state }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Slow Queries (>100ms)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "pg_slow_queries_count",
          "legendFormat": "Slow queries"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Cache Hit Ratio",
      "type": "gauge",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "pg_cache_hit_ratio_ratio * 100",
          "legendFormat": "Cache hit %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Query Execution Time (p95)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "pg_stat_statements_mean_exec_time_seconds{datname=\"vertexchain\"} * 1000",
          "legendFormat": "{{ query }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Replication Lag",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "pg_replication_lag_seconds",
          "legendFormat": "Replication lag"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Table Seq vs Index Scans",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(pg_stat_user_tables_seq_scan{datname=\"vertexchain\"}[5m])",
          "legendFormat": "seq_scan {{ relname }}"
        },
        {
          "expr": "rate(pg_stat_user_tables_idx_scan{datname=\"vertexchain\"}[5m])",
          "legendFormat": "idx_scan {{ relname }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "Dead Tuple Ratio (Bloat)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "pg_stat_user_tables_n_dead_tup{datname=\"vertexchain\"} / (pg_stat_user_tables_n_live_tup{datname=\"vertexchain\"} + pg_stat_user_tables_n_dead_tup{datname=\"vertexchain\"}) * 100",
          "legendFormat": "{{ relname }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent" },
        "overrides": []
      }
    }
  ]
}
